---
import SectionLabel from './SectionLabel.astro';

interface Project {
  icon: string;
  title: string;
  description: string;
  tags: string[];
  stat?: string;
}

const projects: Project[] = [
  {
    icon: '⚡',
    title: 'Structured Document Editing Agent',
    description:
      'LLM-powered agent for structured document editing via tool calls. Uses an intermediate representation for safe, consistent multi-step edits — reducing manual editing time by 60%.',
    tags: ['TypeScript', 'AI SDK', 'LLM Agents'],
  },
  {
    icon: '🦀',
    title: 'AI File Organizer',
    description:
      'Rust-built AI tool to organize large, inconsistent directory trees. Two-stage Explorer/Organizer pipeline with semantic indexing, 18x faster cleanup, and a virtual staging layer for safe review before execution.',
    tags: ['Rust', 'Async', 'TUI'],
  },
  {
    icon: '🧠',
    title: 'NeuroTech EEG Gait Decoder',
    description:
      'PyTorch pipeline predicting gait angle from 16-channel EEG for BCI-driven exoskeleton control. CNN-LSTM architecture reaching 5° RMSE on supervised regression.',
    tags: ['Python', 'PyTorch', 'BCI'],
  },
  {
    icon: '🌍',
    title: 'Disaster Response NLP',
    description:
      'Sentiment analysis on ~45K disaster tweets across 14 events using RoBERTa and VADER. Geospatial and textual models identify locations of highest need during wildfire crises.',
    tags: ['Python', 'RoBERTa', 'NLP'],
  },
  {
    icon: '🛡',
    title: 'Disinformation Detection System',
    description:
      'Detection system using Logistic Regression with GloVe embeddings and Bag-of-Words features. 91% accuracy and 87% F1-score on 1,000+ web-scraped samples.',
    tags: ['Python', 'scikit-learn', 'GloVe'],
  },
  {
    icon: '📅',
    title: 'Raycast Calendar Extension',
    description:
      'Productivity extension for calendar management integrated with macOS calendar software via AppleScript. Serving over 10,000 users.',
    tags: ['TypeScript', 'React', 'AppleScript'],
    stat: '10K+ Users',
  },
];
---

<section class="relative z-1 py-32 border-b-2 border-fg" id="projects">
  <div class="max-w-[1400px] mx-auto px-8">
    <SectionLabel label="Projects" number="03" class="reveal" />
    <h2 class="reveal reveal-delay-1 font-display text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-tight leading-[1.1] mb-16 uppercase">
      Selected work
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-0">
      {projects.map((project, i) => (
        <div
          class:list={[
            'group border-2 border-fg p-8 -mt-[2px] -ml-[2px]',
            'transition-all duration-200 cursor-default',
            'hover:bg-fg hover:text-bg',
            'reveal',
            i > 0 && `reveal-delay-${Math.min(i, 5)}`,
          ]}
        >
          {/* Header */}
          <div class="flex justify-between items-start mb-5">
            <span class="text-2xl">{project.icon}</span>
            {project.stat && (
              <span class="text-[0.65rem] tracking-[0.1em] uppercase text-accent font-bold px-2 py-1 border-2 border-accent">
                {project.stat}
              </span>
            )}
          </div>

          {/* Title */}
          <h3 class="font-display text-lg font-bold tracking-tight mb-3 uppercase">
            {project.title}
          </h3>

          {/* Description */}
          <p class="text-[0.8rem] text-muted leading-relaxed mb-6 group-hover:text-bg/70">
            {project.description}
          </p>

          {/* Tags */}
          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="text-[0.6rem] font-bold tracking-[0.1em] uppercase px-2.5 py-1 border-2 border-fg text-muted group-hover:border-bg group-hover:text-bg">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
