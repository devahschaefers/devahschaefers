---
import SectionLabel from "./SectionLabel.astro";
---

<section id="contact" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <SectionLabel number="05" label="Contact" />

    <div class="section-grid reveal">
      <div class="col-span-12 md:col-span-6">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter">Let's talk.</h2>
        <div class="h-px w-8 bg-accent mt-6 mb-8"></div>
        <div class="space-y-3">
          <a href="mailto:devah.schaefers@gmail.com" class="block text-sm tracking-wide text-fg hover:text-accent transition-colors duration-200">
            devah.schaefers@gmail.com
          </a>
          <a href="https://www.linkedin.com/in/devahschaefers/" target="_blank" rel="noopener noreferrer" class="block text-sm tracking-wide text-fg hover:text-accent transition-colors duration-200">
            LinkedIn ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-border-muted py-8">
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
    <p class="text-xs tracking-[0.15em] uppercase text-muted">Devah Schaefers</p>
    <p class="text-xs tracking-[0.15em] uppercase text-muted">© 2026</p>
  </div>
</footer>
