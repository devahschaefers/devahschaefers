---
import SectionLabel from "./SectionLabel.astro";

const projects = [
  {
    number: "01",
    title: "Structured Document Editing Agent",
    tech: "TypeScript / AI SDK",
    tag: "AI",
    desc: "60% time reduction",
  },
  {
    number: "02",
    title: "AI File Organizer",
    tech: "Rust",
    tag: "Systems",
    desc: "18× faster — 10K+ files",
  },
  {
    number: "03",
    title: "NeuroTech EEG Gait Decoder",
    tech: "Python / PyTorch",
    tag: "ML",
    desc: "5° RMSE",
  },
  {
    number: "04",
    title: "Disaster Response NLP",
    tech: "Python / RoBERTa",
    tag: "NLP",
    desc: "45K tweets",
  },
  {
    number: "05",
    title: "Disinformation Detection",
    tech: "Python / scikit-learn",
    tag: "ML",
    desc: "91% accuracy",
  },
  {
    number: "06",
    title: "Raycast Extension",
    tech: "TypeScript / React",
    tag: "Product",
    desc: "10K+ users",
  },
];
---

<section id="projects" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <SectionLabel number="03" label="Projects" />

    <div class="reveal">
      {projects.map((project, i) => (
        <div class="border-t border-border-muted">
          <div class="section-grid py-6 items-center group hover:bg-surface/50 transition-colors duration-200">
            <div class="col-span-1">
              <span class="text-xs font-medium tracking-[0.2em] text-muted">{project.number}</span>
            </div>
            <div class="col-span-12 md:col-span-5 mt-2 md:mt-0">
              <h3 class="text-base font-bold tracking-tight">{project.title}</h3>
            </div>
            <div class="col-span-6 md:col-span-3 mt-1 md:mt-0">
              <p class="text-sm text-muted">{project.tech}</p>
            </div>
            <div class="col-span-5 md:col-span-2 mt-1 md:mt-0 flex items-center justify-between">
              <p class="text-sm text-fg/70">{project.desc}</p>
              <span class="text-[10px] font-medium tracking-[0.2em] uppercase text-accent">{project.tag}</span>
            </div>
          </div>
        </div>
      ))}
      <div class="border-t border-border-muted"></div>
    </div>
  </div>
</section>
