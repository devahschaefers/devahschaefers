---
interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<div class="flex items-center gap-3 mb-12 reveal">
  <span class="text-xs font-medium tracking-[0.2em] uppercase text-muted">{number}</span>
  <div class="h-px w-8 bg-accent"></div>
  <span class="text-xs font-medium tracking-[0.2em] uppercase text-muted">{label}</span>
</div>
