---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Devah Schaefers',
  description = 'UC Berkeley Computer Science & Data Science student building software, AI systems, and data infrastructure.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark only" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="antialiased max-w-[53rem] mx-6 mt-6 lg:mx-auto">
    <main class="flex-auto min-w-0 mt-4 flex flex-col px-2 md:px-4">
      <slot />
    </main>
  </body>
</html>
