---
import SectionLabel from "./SectionLabel.astro";

interface SkillGroup {
  category: string;
  varName: string;
  skills: string[];
}

const skillGroups: SkillGroup[] = [
  {
    category: "Languages",
    varName: "LANG",
    skills: ["Python", "TypeScript", "Rust", "SQL/PostgreSQL", "C/C++", "Java", "CSS"],
  },
  {
    category: "Frameworks & ML",
    varName: "FW_ML",
    skills: [
      "React/Next.js",
      "React Native",
      "Flask",
      "PyTorch",
      "TorchGeometric",
      "scikit-learn",
      "Pandas/NumPy",
      "Drizzle ORM",
    ],
  },
  {
    category: "Data & Systems",
    varName: "DATA",
    skills: [
      "Data Modeling",
      "ETL/ELT",
      "Web Scraping",
      "Batch Processing",
      "Async Processing",
      "Schema Design",
      "Query Profiling",
    ],
  },
  {
    category: "Tools",
    varName: "TOOLS",
    skills: ["Git/GitHub", "GitLab", "Supabase", "PostgreSQL", "SQLite", "CI/CD"],
  },
];
---

<section id="skills" class="py-20 px-4">
  <div class="max-w-4xl mx-auto reveal">
    <SectionLabel label="Skills" />

    <p class="font-body text-sm text-muted mb-8">
      <span class="text-accent">$</span> env
    </p>

    <div class="terminal-titlebar rounded-t">
      <span class="dot bg-red-500/80"></span>
      <span class="dot bg-yellow-500/80"></span>
      <span class="dot bg-green-500/80"></span>
      <span class="ml-2 text-fg/60">environment variables</span>
    </div>

    <div class="terminal-block rounded-b border-t-0 p-4 sm:p-6 space-y-5">
      {skillGroups.map((group) => (
        <div>
          <p class="font-display text-xs sm:text-sm mb-2">
            <span class="text-accent">{group.varName}</span><span class="text-muted">=</span><span class="text-fg">"</span>
          </p>
          <div class="flex flex-wrap gap-x-3 gap-y-1 pl-4 border-l-2 border-border-muted">
            {group.skills.map((skill, i) => (
              <span class="font-body text-xs sm:text-sm text-fg/80">
                {skill}{i < group.skills.length - 1 ? <span class="text-muted"> | </span> : ""}
              </span>
            ))}
          </div>
          <span class="font-display text-xs text-fg">"</span>
        </div>
      ))}

      <div class="pt-4 border-t border-border-muted">
        <p class="font-body text-xs text-muted">
          <span class="text-accent">$</span> echo $SHELL → <span class="text-fg/70">/bin/zsh</span>
        </p>
        <p class="font-body text-xs text-muted">
          <span class="text-accent">$</span> uname -a → <span class="text-fg/70">PersonalXite 6.0.0 x86_64</span>
        </p>
      </div>
    </div>
  </div>
</section>
