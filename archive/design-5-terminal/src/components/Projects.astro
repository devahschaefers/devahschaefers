---
import SectionLabel from "./SectionLabel.astro";

interface Project {
  name: string;
  description: string;
  tech: string[];
  metric: string;
  type: string;
}

const projects: Project[] = [
  {
    name: "structured-doc-agent",
    description: "AI agent for structured document editing — 60% time reduction in document workflows.",
    tech: ["TypeScript", "AI SDK"],
    metric: "60% time reduction",
    type: "drwxr-xr-x",
  },
  {
    name: "ai-file-organizer",
    description: "Intelligent file organization engine in Rust — 18x faster than alternatives, processing 10K+ files.",
    tech: ["Rust"],
    metric: "18x faster",
    type: "drwxr-xr-x",
  },
  {
    name: "eeg-gait-decoder",
    description: "CNN-LSTM neural decoder for EEG gait prediction with 5° RMSE accuracy.",
    tech: ["Python", "PyTorch"],
    metric: "5° RMSE",
    type: "drwxr-xr-x",
  },
  {
    name: "disaster-response-nlp",
    description: "NLP pipeline classifying 45K disaster-related tweets for real-time emergency response.",
    tech: ["Python", "RoBERTa"],
    metric: "45K tweets",
    type: "-rw-r--r--",
  },
  {
    name: "disinfo-detector",
    description: "Disinformation detection system achieving 91% accuracy across multiple content categories.",
    tech: ["Python", "scikit-learn"],
    metric: "91% accuracy",
    type: "-rw-r--r--",
  },
  {
    name: "raycast-extension",
    description: "Productivity extension for Raycast with 10K+ active users in the ecosystem.",
    tech: ["TypeScript", "React"],
    metric: "10K+ users",
    type: "drwxr-xr-x",
  },
];
---

<section id="projects" class="py-20 px-4">
  <div class="max-w-4xl mx-auto reveal">
    <SectionLabel label="Projects" />

    <p class="font-body text-sm text-muted mb-8">
      <span class="text-accent">$</span> ls -la ~/projects/
    </p>

    <div class="terminal-titlebar rounded-t">
      <span class="dot bg-red-500/80"></span>
      <span class="dot bg-yellow-500/80"></span>
      <span class="dot bg-green-500/80"></span>
      <span class="ml-2 text-fg/60">~/projects/ — 6 items</span>
    </div>

    <div class="terminal-block rounded-b border-t-0 p-0 overflow-hidden">
      <div class="px-4 py-2 bg-bg/80 border-b border-border-muted font-display text-xs text-muted">
        total 42
      </div>

      <div class="divide-y divide-border-muted">
        {projects.map((project) => (
          <div class="group p-4 sm:p-5 hover:bg-card-hover transition-colors box-glow-hover cursor-default">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
              <div class="flex items-center gap-2">
                <span class="font-body text-xs text-muted hidden sm:inline">{project.type}</span>
                <h3 class="font-display text-sm text-fg group-hover:text-accent transition-colors terminal-glow-sm">
                  {project.name}/
                </h3>
              </div>
              <span class="font-body text-xs text-accent shrink-0">
                [{project.metric}]
              </span>
            </div>
            <p class="font-body text-xs sm:text-sm text-fg/70 mb-3">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {project.tech.map((t) => (
                <span class="font-body text-xs px-2 py-0.5 border border-border-muted bg-dim-green/20 text-fg/70 rounded">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
