---
---

<section class="min-h-screen flex items-center justify-center pt-12 px-4 relative">
  <div class="max-w-4xl w-full">
    <div class="terminal-titlebar rounded-t">
      <span class="dot bg-red-500/80"></span>
      <span class="dot bg-yellow-500/80"></span>
      <span class="dot bg-green-500/80"></span>
      <span class="ml-2 text-fg/60">devah@berkeley:~</span>
    </div>

    <div class="terminal-block rounded-b border-t-0 p-6 sm:p-8">
      <div class="space-y-1 text-sm font-body text-muted mb-6">
        <p class="animate-boot-line" style="animation-delay: 0.1s">BIOS v4.2.0 — initializing...</p>
        <p class="animate-boot-line" style="animation-delay: 0.3s">Loading kernel modules... OK</p>
        <p class="animate-boot-line" style="animation-delay: 0.5s">Mounting filesystems... OK</p>
        <p class="animate-boot-line" style="animation-delay: 0.7s">Starting network daemon... OK</p>
        <p class="animate-boot-line" style="animation-delay: 0.9s">══════════════════════════════════════════════════</p>
        <p class="animate-boot-line" style="animation-delay: 1.1s">WELCOME TO TERMINAL.OS v1.0.0</p>
        <p class="animate-boot-line" style="animation-delay: 1.3s">══════════════════════════════════════════════════</p>
      </div>

      <div class="mb-8">
        <p class="font-body text-muted text-sm mb-1">login:</p>
        <h1 class="font-display text-4xl sm:text-5xl md:text-7xl font-extrabold terminal-glow animate-pulse-glow leading-tight">
          Devah<br/>Schaefers
        </h1>
      </div>

      <div class="space-y-2 mb-8 font-body text-sm text-fg/70">
        <p><span class="text-accent">┌──</span><span class="text-border-muted">──────────────────────────────────────</span></p>
        <p><span class="text-accent">│</span> <span class="text-muted">role:</span> <span class="text-fg">CS & Data Science Student @ UC Berkeley</span></p>
        <p><span class="text-accent">│</span> <span class="text-muted">focus:</span> <span class="text-fg">ML Engineering · Data Science · Full-Stack</span></p>
        <p><span class="text-accent">│</span> <span class="text-muted">gpa:</span> <span class="text-accent">3.97</span></p>
        <p><span class="text-accent">└──</span><span class="text-border-muted">──────────────────────────────────────</span></p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 font-display text-sm px-5 py-2.5 border border-fg/40 hover:border-fg bg-dim-green/30 hover:bg-dim-green/60 transition-all box-glow-hover rounded"
        >
          <span class="text-accent">$</span> cat projects.log
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 font-display text-sm px-5 py-2.5 border border-accent/40 hover:border-accent bg-accent/5 hover:bg-accent/10 transition-all rounded"
        >
          <span class="text-accent">$</span> mail devah
        </a>
      </div>

      <div class="mt-8 font-body text-sm text-muted">
        <span class="text-accent">devah@berkeley:~$</span> <span class="blinking-cursor"></span>
      </div>
    </div>
  </div>
</section>
