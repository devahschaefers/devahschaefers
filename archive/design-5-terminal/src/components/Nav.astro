---
const links = [
  { href: "#about", label: "about" },
  { href: "#experience", label: "experience" },
  { href: "#projects", label: "projects" },
  { href: "#skills", label: "skills" },
  { href: "#contact", label: "contact" },
];
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 bg-bg/95 backdrop-blur-sm border-b border-border-muted">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-12">
      <a href="#" class="font-display text-sm terminal-glow-sm flex items-center gap-2">
        <span class="text-accent">devah@terminal</span><span class="text-fg">:</span><span class="text-muted">~</span><span class="text-accent">$</span>
      </a>

      <div class="hidden md:flex items-center gap-1">
        {links.map((link) => (
          <a
            href={link.href}
            class="font-display text-xs px-3 py-1.5 hover:bg-dim-green/50 transition-colors rounded"
          >
            <span class="text-accent">$</span> <span class="text-fg/80">{link.label}</span>
          </a>
        ))}
      </div>

      <button
        id="mobile-toggle"
        class="md:hidden font-display text-xs text-accent px-2 py-1 border border-border-muted hover:bg-dim-green/50 transition-colors"
        aria-label="Toggle menu"
      >
        [=]
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border-muted bg-bg/98">
    <div class="px-4 py-3 space-y-1">
      {links.map((link) => (
        <a
          href={link.href}
          class="block font-display text-sm py-1.5 hover:bg-dim-green/50 transition-colors"
        >
          <span class="text-accent">$</span> {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    toggle.textContent = menu?.classList.contains("hidden") ? "[=]" : "[x]";
  });

  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      menu?.classList.add("hidden");
      if (toggle) toggle.textContent = "[=]";
    });
  });
</script>
