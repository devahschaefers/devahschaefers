---
interface Props {
  label: string;
}

const { label } = Astro.props;
const formatted = label.toLowerCase().replace(/\s+/g, "_");
---

<div class="flex items-center gap-3 mb-6">
  <span class="text-accent font-display text-sm">//</span>
  <span class="text-muted font-display text-sm tracking-widest uppercase">{formatted}</span>
  <span class="flex-1 h-px bg-border-muted"></span>
  <span class="text-muted font-display text-xs">[{label}]</span>
</div>
