---
import Layout from '../../layouts/Layout.astro';
import { categories } from '../../data/experience';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.id },
    props: { cat },
  }));
}

const { cat } = Astro.props;
---

<Layout title={`Devah Schaefers — ${cat.label} Experience`} description={cat.tagline}>
  <div class="min-h-screen pt-32 pb-24">
    <div class="max-w-[900px] mx-auto px-8">
      <a
        href="/#experience"
        class="inline-flex items-center gap-2 text-[0.7rem] font-medium tracking-[0.1em] uppercase text-text-muted hover:text-accent transition-colors mb-10"
      >
        ← Back
      </a>

      <div class="mb-4">
        <span class="text-[0.65rem] font-bold tracking-[0.15em] uppercase text-accent px-2.5 py-1 border border-accent/20 rounded-sm bg-accent/5">
          {cat.label}
        </span>
      </div>
      <h1 class="font-display text-[clamp(1.8rem,3.5vw,2.8rem)] font-bold tracking-tight leading-[1.15] mb-3">
        {cat.tagline}
      </h1>

      <div class="w-full h-px bg-gradient-to-r from-accent/40 via-border to-transparent mt-8 mb-14" />

      <div class="space-y-16">
        {cat.experiences.map((exp) => (
          <article class="relative pl-10 before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0 before:w-px before:bg-gradient-to-b before:from-accent before:via-border before:to-transparent">
            <div class="absolute -left-[2.4rem] top-1.5 w-2.5 h-2.5 border-2 border-accent rounded-full bg-bg-primary" />

            <div class="mb-3">
              <div class="font-display text-xl font-bold tracking-tight text-text-primary">
                {exp.role}
              </div>
              <div class="text-sm text-accent font-medium">{exp.company}</div>
            </div>

            <div class="text-[0.7rem] tracking-[0.08em] uppercase text-text-muted flex gap-5 mb-5">
              <span>{exp.dates}</span>
              <span>{exp.location}</span>
            </div>

            <ul class="flex flex-col gap-2.5 list-none mb-5">
              {exp.bullets.map((bullet) => (
                <li class="text-[0.82rem] text-text-secondary pl-5 relative leading-relaxed before:content-['▹'] before:absolute before:left-0 before:text-accent before:text-[0.7rem]">
                  {bullet}
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-1.5">
              {exp.tech.map((t) => (
                <span class="text-[0.62rem] font-semibold tracking-[0.08em] uppercase px-3 py-1 border border-border rounded-sm text-text-muted">
                  {t}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="mt-16 pt-8 border-t border-border">
        <div class="flex flex-wrap gap-3">
          {categories.filter((c) => c.id !== cat.id).map((c) => (
            <a
              href={`/experience/${c.id}`}
              class="text-[0.7rem] font-medium tracking-[0.1em] uppercase text-text-muted hover:text-accent
                     px-3 py-1.5 border border-border rounded-sm transition-all duration-300 hover:border-accent/30"
            >
              {c.label} →
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
