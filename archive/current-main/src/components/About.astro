---
import SectionLabel from './SectionLabel.astro';

const stats = [
  { value: '3.97', label: 'GPA at UC Berkeley' },
  { value: '15+', label: 'Developers Led' },
  { value: '10K+', label: 'Extension Users' },
  { value: '2M+', label: 'Positions Evaluated' },
];
---

<section
  class="relative z-1 py-32 bg-gradient-to-b from-bg-primary to-bg-secondary"
  id="about"
>
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Text -->
      <div class="reveal">
        <SectionLabel label="About" />
        <h2 class="font-display text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight leading-[1.15] mb-12">
          Building across the<br />full stack &amp; beyond
        </h2>
        <p class="text-sm text-text-secondary mb-6 leading-relaxed first-line:text-text-primary first-line:font-medium">
          I'm a UC Berkeley student studying Computer Science and Data Science,
          with a focus on building systems that bridge software engineering,
          machine learning, and data infrastructure.
        </p>
        <p class="text-sm text-text-secondary mb-6 leading-relaxed">
          My work spans LLM-powered agents, applied ML research on EEG data for
          brain-computer interfaces, high-volume data pipelines, and full-stack
          internal platforms serving hundreds of users. I care about craft —
          clean architecture, thoughtful abstractions, and shipping things that
          actually work at scale.
        </p>
        <p class="text-sm text-text-secondary leading-relaxed">
          I work across Python, TypeScript, Rust, SQL, React/Next.js, PyTorch,
          PostgreSQL, and modern AI/LLM tooling.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-6 reveal reveal-delay-2">
        {stats.map(({ value, label }) => (
          <div
            class="group relative overflow-hidden bg-bg-card border border-border rounded-sm p-7
                   transition-all duration-400 ease-[var(--ease-out-expo)]
                   hover:border-border-hover hover:-translate-y-0.5"
          >
            {/* Top glow line */}
            <span class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400" />
            <div class="font-display text-3xl font-extrabold text-accent leading-none mb-1.5">
              {value}
            </div>
            <div class="text-[0.7rem] tracking-[0.1em] uppercase text-text-muted">
              {label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
