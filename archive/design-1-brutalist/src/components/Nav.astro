---
const links = [
  { href: '#about', label: 'ABOUT', num: '01' },
  { href: '#experience', label: 'EXPERIENCE', num: '02' },
  { href: '#projects', label: 'PROJECTS', num: '03' },
  { href: '#skills', label: 'SKILLS', num: '04' },
  { href: '#contact', label: 'CONTACT', num: '05' },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-[1000] flex items-center justify-between px-8 py-4
         bg-bg border-b-2 border-fg transition-all duration-300"
>
  <a href="#hero" class="font-display font-bold text-xl tracking-tight text-fg">
    DEVAH<span class="text-accent">.</span>
  </a>

  <ul class="hidden md:flex gap-8 list-none">
    {links.map(({ href, label, num }) => (
      <li>
        <a
          href={href}
          class="text-[0.7rem] font-medium tracking-[0.12em] text-muted hover:text-fg transition-colors duration-200"
        >
          <span class="text-accent">{num}.</span> {label}
        </a>
      </li>
    ))}
  </ul>

  <button
    class="flex flex-col gap-[6px] md:hidden cursor-pointer p-1 bg-transparent border-none"
    id="nav-toggle"
    aria-label="Toggle navigation"
  >
    <span class="block w-[24px] h-[2px] bg-fg transition-all duration-300"></span>
    <span class="block w-[24px] h-[2px] bg-fg transition-all duration-300"></span>
    <span class="block w-[24px] h-[2px] bg-fg transition-all duration-300"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed top-[54px] left-0 right-0 z-[999] flex-col gap-4 px-8 py-6
         bg-bg border-b-2 border-fg hidden"
>
  {links.map(({ href, label, num }) => (
    <a
      href={href}
      class="mobile-link block text-[0.7rem] font-medium tracking-[0.12em] text-muted hover:text-fg transition-colors duration-200"
    >
      <span class="text-accent">{num}.</span> {label}
    </a>
  ))}
</div>

<script>
  // Mobile toggle
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
  });
  mobileMenu?.querySelectorAll('.mobile-link').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex');
    });
  });
</script>
