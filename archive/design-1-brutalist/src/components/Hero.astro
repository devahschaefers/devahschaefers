---

---

<section class="relative z-1 min-h-screen flex items-center border-b-2 border-fg" id="hero">
  <div class="max-w-[1400px] mx-auto px-8 w-full py-24">
    <!-- Tag -->
    <div
      class="font-body text-xs font-medium tracking-[0.15em] uppercase text-muted
             mb-8 flex items-center gap-3
             opacity-0 animate-[fadeSlideUp_0.6s_ease_0.2s_forwards]"
    >
      <span class="inline-block w-3 h-[2px] bg-accent"></span>
      Available for opportunities
    </div>

    <!-- Name — MASSIVE -->
    <h1
      class="font-display font-bold tracking-[-0.04em] leading-[0.9] mb-8
             text-[clamp(3.5rem,10vw,12rem)] uppercase
             opacity-0 animate-[fadeSlideUp_0.6s_ease_0.4s_forwards]"
    >
      <span class="block text-fg">Devah</span>
      <span class="block text-fg">Schaefers<span class="text-accent">.</span></span>
    </h1>

    <!-- Tagline with blinking cursor -->
    <p
      class="font-body text-[clamp(0.85rem,1.3vw,1rem)] font-light leading-relaxed
             text-muted max-w-[600px] mb-12
             opacity-0 animate-[fadeSlideUp_0.6s_ease_0.6s_forwards]"
    >
      UC Berkeley Computer Science &amp; Data Science student building software,
      AI systems, and data infrastructure. From neural decoders to full-stack
      platforms — I ship things that work<span class="inline-block w-[2px] h-[1em] bg-accent ml-0.5 align-middle animate-[blink_1s_step-end_infinite]"></span>
    </p>

    <!-- CTAs -->
    <div class="flex gap-4 flex-wrap opacity-0 animate-[fadeSlideUp_0.6s_ease_0.8s_forwards]">
      <a
        href="https://www.linkedin.com/in/devahschaefers/"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-8 py-4 font-body text-xs font-semibold
               tracking-[0.08em] uppercase cursor-pointer
               bg-fg text-bg border-2 border-fg
               transition-all duration-200
               hover:bg-accent hover:border-accent hover:text-bg"
      >
        LinkedIn
      </a>
      <a
        href="mailto:devah.schaefers@gmail.com"
        class="inline-flex items-center gap-2 px-8 py-4 font-body text-xs font-semibold
               tracking-[0.08em] uppercase cursor-pointer
               bg-transparent text-fg border-2 border-fg
               transition-all duration-200
               hover:bg-fg hover:text-bg"
      >
        Get in Touch
      </a>
    </div>
  </div>

  <!-- Side text -->
  <div
    class="absolute right-8 top-1/2 -translate-y-1/2 rotate-90 origin-center
           text-[0.6rem] tracking-[0.3em] uppercase text-muted
           opacity-0 animate-[fadeIn_0.6s_ease_1s_forwards]
           hidden md:block"
  >
    Berkeley, CA — CS &amp; Data Science
  </div>
</section>
