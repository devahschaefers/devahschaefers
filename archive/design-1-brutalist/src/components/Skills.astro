---
import SectionLabel from './SectionLabel.astro';

interface SkillGroup {
  title: string;
  items: string[];
}

const groups: SkillGroup[] = [
  {
    title: 'Languages',
    items: ['Python', 'TypeScript', 'Rust', 'SQL / PostgreSQL', 'C / C++', 'Java', 'CSS'],
  },
  {
    title: 'Frameworks & ML',
    items: [
      'React / Next.js',
      'React Native',
      'Flask',
      'PyTorch',
      'TorchGeometric',
      'scikit-learn',
      'Pandas / NumPy',
      'Drizzle ORM',
    ],
  },
  {
    title: 'Data & Systems',
    items: [
      'Data Modeling',
      'ETL / ELT',
      'Web Scraping',
      'Batch Processing',
      'Async Processing',
      'Schema Design',
      'Query Profiling',
    ],
  },
  {
    title: 'Tools & Platforms',
    items: ['Git / GitHub', 'GitLab', 'Supabase', 'PostgreSQL', 'SQLite', 'CI/CD'],
  },
];
---

<section class="relative z-1 py-32 border-b-2 border-fg" id="skills">
  <div class="max-w-[1400px] mx-auto px-8">
    <SectionLabel label="Skills" number="04" class="reveal" />
    <h2 class="reveal reveal-delay-1 font-display text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-tight leading-[1.1] mb-16 uppercase">
      Technical toolkit
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-0">
      {groups.map((group, gi) => (
        <div class:list={['border-2 border-fg -mt-[2px] -ml-[2px] p-8 reveal', gi > 0 && `reveal-delay-${gi}`]}>
          <h3 class="font-display text-sm font-bold tracking-[0.15em] uppercase text-accent mb-6 pb-3 border-b-2 border-fg">
            {group.title}
          </h3>
          <div class="flex flex-col gap-0">
            {group.items.map((item) => (
              <div class="text-[0.78rem] text-muted py-2 border-b border-border-muted last:border-b-0
                          hover:text-fg hover:bg-fg hover:text-bg hover:pl-3 transition-all duration-150 cursor-default">
                {item}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
