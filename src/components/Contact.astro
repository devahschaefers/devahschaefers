---
import SectionLabel from './SectionLabel.astro';
---

<section
  class="relative z-1 pt-32 pb-16 bg-gradient-to-b from-bg-primary to-bg-secondary section-divider"
  id="contact"
>
  <div class="max-w-[1200px] mx-auto px-8">
    <!-- Content -->
    <div class="text-center max-w-xl mx-auto reveal">
      <SectionLabel label="Contact" centered />
      <h2 class="font-serif text-[clamp(2.5rem,5vw,4rem)] italic font-normal tracking-tight leading-[1.15] mb-6 text-text-primary">
        Let's build something<br />together.
      </h2>
      <p class="text-sm text-text-secondary mb-10 leading-relaxed">
        I'm always open to interesting conversations about software, AI, data,
        or new opportunities. Drop me a line.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16">
        <a
          href="mailto:devah.schaefers@gmail.com"
          class="inline-flex items-center justify-center gap-2 px-6 py-3
                 text-xs font-medium tracking-[0.08em] uppercase
                 border border-border rounded-sm text-text-secondary
                 transition-all duration-400 ease-[var(--ease-out-expo)]
                 hover:border-accent hover:text-accent hover:shadow-[0_0_25px_var(--color-accent-glow)]"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          devah.schaefers@gmail.com
        </a>
        <a
          href="https://www.linkedin.com/in/devahschaefers/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 px-6 py-3
                 text-xs font-medium tracking-[0.08em] uppercase
                 border border-border rounded-sm text-text-secondary
                 transition-all duration-400 ease-[var(--ease-out-expo)]
                 hover:border-accent hover:text-accent hover:shadow-[0_0_25px_var(--color-accent-glow)]"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Footer -->
    <footer class="border-t border-border pt-8 flex flex-col sm:flex-row justify-between items-center gap-3">
      <span class="text-[0.65rem] tracking-[0.1em] uppercase text-text-muted">
        &copy; 2026 Devah Schaefers
      </span>
      <span class="text-[0.65rem] tracking-[0.1em] uppercase text-text-muted">
        Designed & built with <span class="text-accent">precision</span>
      </span>
    </footer>
  </div>
</section>
