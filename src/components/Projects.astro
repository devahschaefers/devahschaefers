---
interface Project {
  title: string;
  description: string;
  tags: string[];
  stat?: string;
}

const projects: Project[] = [
  {
    title: 'Structured Document Editing Agent',
    description:
      'LLM-powered agent for structured document editing via tool calls. Uses an intermediate representation for safe, consistent multi-step edits \u2014 reducing manual editing time by 60%.',
    tags: ['TypeScript', 'AI SDK', 'LLM Agents'],
  },
  {
    title: 'AI File Organizer',
    description:
      'Rust-built AI tool to organize large, inconsistent directory trees. Two-stage Explorer/Organizer pipeline with semantic indexing, 18x faster cleanup, and a virtual staging layer for safe review.',
    tags: ['Rust', 'Async', 'TUI'],
  },
  {
    title: 'NeuroTech EEG Gait Decoder',
    description:
      'PyTorch pipeline predicting gait angle from 16-channel EEG for BCI-driven exoskeleton control. CNN-LSTM architecture reaching 5\u00b0 RMSE on supervised regression.',
    tags: ['Python', 'PyTorch', 'BCI'],
  },
  {
    title: 'Disaster Response NLP',
    description:
      'Sentiment analysis on ~45K disaster tweets across 14 events using RoBERTa and VADER. Geospatial and textual models identify locations of highest need during wildfire crises.',
    tags: ['Python', 'RoBERTa', 'NLP'],
  },
  {
    title: 'Disinformation Detection System',
    description:
      'Detection system using Logistic Regression with GloVe embeddings and Bag-of-Words features. 91% accuracy and 87% F1-score on 1,000+ web-scraped samples.',
    tags: ['Python', 'scikit-learn', 'GloVe'],
  },
  {
    title: 'Raycast Calendar Extension',
    description:
      'Productivity extension for calendar management integrated with macOS calendar software via AppleScript. Serving over 10,000 users.',
    tags: ['TypeScript', 'React', 'AppleScript'],
    stat: '10K+ users',
  },
];
---

<section class="py-10" id="projects">
  <h2 class="section-heading">projects</h2>

  <div class="space-y-4">
    {projects.map((project) => (
      <div class="experience-item">
        <div class="flex items-start justify-between gap-3 mb-1">
          <h3 class="font-semibold text-text text-[15px] leading-snug">
            {project.title}
          </h3>
          {project.stat && (
            <span class="text-xs text-text-muted shrink-0 border border-border rounded-full px-2.5 py-0.5">
              {project.stat}
            </span>
          )}
        </div>

        <p class="text-sm text-text-secondary leading-relaxed mb-3">
          {project.description}
        </p>

        <div class="flex flex-wrap gap-1.5">
          {project.tags.map((tag) => (
            <span class="tech-tag">{tag}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
