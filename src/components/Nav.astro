---
interface Props {
  current?: string;
}

const { current = 'home' } = Astro.props;

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/experience', label: 'Work', key: 'experience' },
  { href: '/classes', label: 'Classes', key: 'classes' },
];
---

<aside class="mb-12 tracking-tight">
  <div class="lg:sticky lg:top-20">
    <nav class="flex items-center justify-center relative px-0 pb-0 py-3">
      <div class="flex flex-wrap md:flex-nowrap items-center justify-center gap-x-4 gap-y-2 w-full md:w-auto">
        {links.map(({ href, label, key }) => (
          <a
            href={href}
            class:list={['nav-link', current === key && 'active']}
          >
            {label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</aside>
