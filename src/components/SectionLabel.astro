---
interface Props {
  label: string;
  class?: string;
  centered?: boolean;
}

const { label, class: className = '', centered = false } = Astro.props;
---

<div
  class:list={[
    'font-mono text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-accent',
    'mb-3 flex items-center gap-3',
    centered && 'justify-center',
    className,
  ]}
>
  <span class="w-7 h-px bg-accent"></span>
  {label}
</div>
