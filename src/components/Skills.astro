---
import SectionLabel from './SectionLabel.astro';

interface SkillGroup {
  title: string;
  items: string[];
}

const groups: SkillGroup[] = [
  {
    title: 'Languages',
    items: ['Python', 'TypeScript', 'Rust', 'SQL / PostgreSQL', 'C / C++', 'Java', 'CSS'],
  },
  {
    title: 'Frameworks & ML',
    items: [
      'React / Next.js',
      'React Native',
      'Flask',
      'PyTorch',
      'TorchGeometric',
      'scikit-learn',
      'Pandas / NumPy',
      'Drizzle ORM',
    ],
  },
  {
    title: 'Data & Systems',
    items: [
      'Data Modeling',
      'ETL / ELT',
      'Web Scraping',
      'Batch Processing',
      'Async Processing',
      'Schema Design',
      'Query Profiling',
    ],
  },
  {
    title: 'Tools & Platforms',
    items: ['Git / GitHub', 'GitLab', 'Supabase', 'PostgreSQL', 'SQLite', 'CI/CD'],
  },
];
---

<section class="relative z-1 py-32 section-divider" id="skills">
  <div class="max-w-[1200px] mx-auto px-8">
    <SectionLabel label="Skills" class="reveal" />
    <h2 class="reveal reveal-delay-1 font-display text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight leading-[1.15] mb-12">
      Technical toolkit
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-8">
      {groups.map((group, gi) => (
        <div class:list={['reveal', gi > 0 && `reveal-delay-${gi}`]}>
          <h3 class="font-display text-sm font-bold tracking-wide text-text-primary mb-5 pb-3 border-b border-border">
            {group.title}
          </h3>
          <div class="flex flex-col gap-2">
            {group.items.map((item) => (
              <div class="group/skill text-[0.78rem] text-text-secondary py-1.5 pl-4 relative cursor-default transition-all duration-300 hover:text-accent hover:translate-x-1">
                <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-1 rounded-full bg-text-muted transition-all duration-300 group-hover/skill:bg-accent group-hover/skill:shadow-[0_0_6px_var(--color-accent-glow-strong)]" />
                {item}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
