---
import { statSync } from 'node:fs';
import { resolve } from 'node:path';
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
  description?: string;
  current?: string;
  centered?: boolean;
}

const {
  title = 'Devah Schaefers',
  description = 'UC Berkeley Computer Science & Data Science student building software, AI systems, and data infrastructure.',
  current = 'home',
  centered = false,
} = Astro.props;

const faviconVersion = Math.trunc(
  statSync(resolve(process.cwd(), 'public/favicon.svg')).mtimeMs,
);
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark only" />
    <meta name="theme-color" content="#1e1e22" />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="antialiased min-h-[calc(100dvh/1.7)] flex flex-col max-w-[53rem] mx-6 pt-4 lg:mx-auto">
    <div class="bg-ambient" aria-hidden="true">
      <span class="blob blob-1"><span class="blob-inner"></span></span>
      <span class="blob blob-3"><span class="blob-inner"></span></span>
      <span class="blob blob-4"><span class="blob-inner"></span></span>
      <span class="blob blob-5"><span class="blob-inner"></span></span>
      <span class="blob blob-6"><span class="blob-inner"></span></span>
    </div>
    <div class="bg-grain" aria-hidden="true"></div>
    <Nav current={current} />
    <main class:list={["flex-1 min-w-0 flex flex-col px-2 md:px-4 py-8", centered && "justify-center"]}>
      <slot />
    </main>

    <script>
      // Cursor-proximity highlight for the ambient blobs.
      // On each pointer move we find the blob whose center is
      // closest to the cursor and give only it `.blob--nearest`,
      // which triggers the ::after glow in global.css. Throttled
      // to rAF; bails on reduced-motion / coarse pointers.
      (() => {
        if (
          window.matchMedia("(prefers-reduced-motion: reduce)").matches ||
          window.matchMedia("(pointer: coarse)").matches
        ) {
          return;
        }

        const blobs = Array.from(
          document.querySelectorAll<HTMLElement>(".bg-ambient .blob"),
        );
        if (blobs.length === 0) return;

        let currentNearest: HTMLElement | null = null;
        let mouseX = -1;
        let mouseY = -1;
        let pending = false;

        const update = () => {
          pending = false;
          // Per-blob threshold: cursor must be within ~0.6 of
          // a blob's own radius from its center. Since blobs
          // have soft gradient falloff well past their box,
          // this roughly means "the cursor is over the bright
          // core of the blob" rather than "somewhere on screen".
          let minRatio = Infinity;
          let winner: HTMLElement | null = null;
          for (const blob of blobs) {
            const r = blob.getBoundingClientRect();
            const cx = r.left + r.width / 2;
            const cy = r.top + r.height / 2;
            const d = Math.hypot(cx - mouseX, cy - mouseY);
            const radius = Math.max(r.width, r.height) / 2;
            // Normalize: distance as a fraction of this blob's
            // own radius, so small and large blobs compete on
            // equal terms.
            const ratio = d / radius;
            if (ratio < minRatio) {
              minRatio = ratio;
              winner = blob;
            }
          }
          // Only highlight if cursor is well inside the blob.
          if (minRatio > 0.6) winner = null;

          if (winner !== currentNearest) {
            currentNearest?.classList.remove("blob--nearest");
            winner?.classList.add("blob--nearest");
            currentNearest = winner;
          }
        };

        window.addEventListener(
          "pointermove",
          (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            if (!pending) {
              pending = true;
              requestAnimationFrame(update);
            }
          },
          { passive: true },
        );

        // Clear on pointer leave so the glow fades when the
        // cursor exits the window.
        window.addEventListener("pointerleave", () => {
          currentNearest?.classList.remove("blob--nearest");
          currentNearest = null;
        });
      })();
    </script>
  </body>
</html>
