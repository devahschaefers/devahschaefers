---
interface SkillGroup {
  title: string;
  items: string[];
}

const groups: SkillGroup[] = [
  {
    title: 'languages',
    items: ['Python', 'TypeScript', 'Rust', 'SQL / PostgreSQL', 'C / C++', 'Java', 'CSS'],
  },
  {
    title: 'frameworks & ml',
    items: [
      'React / Next.js',
      'React Native',
      'Flask',
      'PyTorch',
      'TorchGeometric',
      'scikit-learn',
      'Pandas / NumPy',
      'Drizzle ORM',
    ],
  },
  {
    title: 'data & systems',
    items: [
      'Data Modeling',
      'ETL / ELT',
      'Web Scraping',
      'Batch Processing',
      'Async Processing',
      'Schema Design',
      'Query Profiling',
    ],
  },
  {
    title: 'tools & platforms',
    items: ['Git / GitHub', 'GitLab', 'Supabase', 'PostgreSQL', 'SQLite', 'CI/CD'],
  },
];
---

<section class="py-10" id="skills">
  <h2 class="section-heading">skills</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
    {groups.map((group) => (
      <div>
        <h3 class="text-sm font-medium text-text-muted mb-3 pb-2 border-b border-border">
          {group.title}
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {group.items.map((item) => (
            <span
              class="tech-tag cursor-default hover:border-text-muted transition-colors duration-200"
            >
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
