---
import SectionLabel from './SectionLabel.astro';

const stats = [
  { value: '3.97', label: 'GPA at UC Berkeley' },
  { value: '15+', label: 'Developers Led' },
  { value: '10K+', label: 'Extension Users' },
  { value: '2M+', label: 'Positions Evaluated' },
];
---

<section
  class="relative py-28 bg-bg-primary"
  id="about"
>
  <div class="max-w-[900px] mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 items-start">
      <!-- Text — takes 3 of 5 columns -->
      <div class="lg:col-span-3 reveal">
        <SectionLabel label="About" />
        <h2 class="font-serif text-[clamp(1.8rem,3.5vw,2.8rem)] font-bold tracking-tight leading-[1.2] mb-10 text-text-primary">
          Building across the<br />full stack &amp; beyond
        </h2>
        <p class="text-base text-text-secondary mb-5 leading-relaxed">
          I'm a UC Berkeley student studying Computer Science and Data Science,
          with a focus on building systems that bridge software engineering,
          machine learning, and data infrastructure.
        </p>
        <p class="text-base text-text-secondary mb-5 leading-relaxed">
          My work spans LLM-powered agents, applied ML research on EEG data for
          brain-computer interfaces, high-volume data pipelines, and full-stack
          internal platforms serving hundreds of users. I care about craft —
          clean architecture, thoughtful abstractions, and shipping things that
          actually work at scale.
        </p>
        <p class="text-base text-text-secondary leading-relaxed">
          I work across Python, TypeScript, Rust, SQL, React/Next.js, PyTorch,
          PostgreSQL, and modern AI/LLM tooling.
        </p>
      </div>

      <!-- Stats — takes 2 of 5 columns -->
      <div class="lg:col-span-2 grid grid-cols-2 gap-5 reveal reveal-delay-2">
        {stats.map(({ value, label }) => (
          <div
            class="group bg-bg-card border border-border rounded-lg p-6
                   transition-all duration-400 ease-[var(--ease-editorial)]
                   hover:shadow-md hover:-translate-y-0.5"
          >
            <div class="font-serif text-3xl font-bold text-accent leading-none mb-2">
              {value}
            </div>
            <div class="text-[0.72rem] tracking-wide uppercase text-text-muted font-sans">
              {label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
