---
const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#contact', label: 'Contact' },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-[1000] flex items-center justify-between px-8 py-5
         backdrop-blur-2xl backdrop-saturate-150
         bg-bg-primary/60
         border-b border-transparent transition-all duration-400"
>
  <!-- Neon bottom border glow (hidden until scroll) -->
  <div id="nav-glow-line" class="absolute bottom-0 left-0 right-0 h-px opacity-0 transition-opacity duration-400
       bg-gradient-to-r from-transparent via-neon-pink to-transparent
       shadow-[0_1px_12px_rgba(255,45,149,0.4)]"></div>

  <a href="#hero" class="font-display font-extrabold text-lg tracking-tight text-text-primary">
    devah<span class="text-neon-pink neon-text-pink">.</span>
  </a>

  <ul class="nav-links hidden md:flex gap-8 list-none" id="nav-links">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class="nav-link relative text-[0.72rem] font-medium tracking-[0.15em] uppercase text-text-secondary
                 pb-1 hover:text-neon-cyan group transition-all duration-300"
        >
          <span class="opacity-0 group-hover:opacity-60 transition-opacity duration-300 text-neon-cyan">[&nbsp;</span>
          {label}
          <span class="opacity-0 group-hover:opacity-60 transition-opacity duration-300 text-neon-cyan">&nbsp;]</span>
          <span class="absolute bottom-0 left-0 h-px w-0 bg-gradient-to-r from-neon-pink to-neon-cyan transition-all duration-400 ease-[var(--ease-out-expo)] group-hover:w-full
                shadow-[0_0_8px_rgba(0,240,255,0.5)]" />
        </a>
      </li>
    ))}
  </ul>

  <button
    class="flex flex-col gap-[5px] md:hidden cursor-pointer p-1 bg-transparent border-none"
    id="nav-toggle"
    aria-label="Toggle navigation"
  >
    <span class="block w-[22px] h-[1.5px] bg-neon-pink transition-all duration-300"></span>
    <span class="block w-[22px] h-[1.5px] bg-neon-cyan transition-all duration-300"></span>
    <span class="block w-[22px] h-[1.5px] bg-neon-pink transition-all duration-300"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed top-[60px] left-0 right-0 z-[999] flex-col gap-4 px-8 py-6
         bg-bg-primary/95 backdrop-blur-2xl border-b border-border
         hidden"
>
  {links.map(({ href, label }) => (
    <a
      href={href}
      class="mobile-link block text-[0.72rem] font-medium tracking-[0.15em] uppercase text-text-secondary
             hover:text-neon-cyan transition-colors duration-300"
    >
      <span class="text-neon-pink mr-1">//</span>{label}
    </a>
  ))}
</div>

<script>
  // Navbar scroll effect
  const nav = document.getElementById('navbar');
  const glowLine = document.getElementById('nav-glow-line');
  window.addEventListener('scroll', () => {
    if (nav && glowLine) {
      if (window.scrollY > 50) {
        nav.classList.add('py-3');
        nav.classList.remove('py-5', 'border-transparent');
        nav.classList.add('border-b-border');
        glowLine.classList.remove('opacity-0');
        glowLine.classList.add('opacity-100');
      } else {
        nav.classList.remove('py-3', 'border-b-border');
        nav.classList.add('py-5', 'border-transparent');
        glowLine.classList.add('opacity-0');
        glowLine.classList.remove('opacity-100');
      }
    }
  }, { passive: true });

  // Mobile toggle
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
  });
  mobileMenu?.querySelectorAll('.mobile-link').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex');
    });
  });
</script>
