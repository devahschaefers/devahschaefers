---
import SectionLabel from './SectionLabel.astro';

interface SkillGroup {
  title: string;
  items: string[];
}

const groups: SkillGroup[] = [
  {
    title: 'Languages',
    items: ['Python', 'TypeScript', 'Rust', 'SQL / PostgreSQL', 'C / C++', 'Java', 'CSS'],
  },
  {
    title: 'Frameworks & ML',
    items: [
      'React / Next.js',
      'React Native',
      'Flask',
      'PyTorch',
      'TorchGeometric',
      'scikit-learn',
      'Pandas / NumPy',
      'Drizzle ORM',
    ],
  },
  {
    title: 'Data & Systems',
    items: [
      'Data Modeling',
      'ETL / ELT',
      'Web Scraping',
      'Batch Processing',
      'Async Processing',
      'Schema Design',
      'Query Profiling',
    ],
  },
  {
    title: 'Tools & Platforms',
    items: ['Git / GitHub', 'GitLab', 'Supabase', 'PostgreSQL', 'SQLite', 'CI/CD'],
  },
];
---

<section class="relative z-1 py-32 section-divider" id="skills">
  <div class="max-w-[1200px] mx-auto px-8">
    <SectionLabel label="Skills" class="reveal" />
    <h2 class="reveal reveal-delay-1 font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold tracking-tight leading-[1.15] mb-12 text-text-primary">
      Technical toolkit
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-8">
      {groups.map((group, gi) => (
        <div class:list={['reveal', gi > 0 && `reveal-delay-${gi}`]}>
          <h3 class="font-display text-sm font-bold tracking-wide text-text-primary mb-5 pb-3
                     border-b border-gradient-to-r from-neon-pink to-neon-cyan"
              style="border-image: linear-gradient(to right, #ff2d95, #00f0ff) 1;">
            <span class="text-neon-cyan mr-1.5 opacity-60">//</span>{group.title}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="skill-pill text-[0.72rem] font-medium tracking-[0.04em] px-3.5 py-1.5
                           border border-border rounded-sm text-text-secondary
                           bg-bg-card/40 backdrop-blur-sm
                           transition-all duration-300 cursor-default
                           hover:border-neon-pink hover:text-neon-pink hover:bg-neon-pink/[0.06]
                           hover:shadow-[0_0_12px_rgba(255,45,149,0.2),inset_0_0_12px_rgba(255,45,149,0.05)]">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
