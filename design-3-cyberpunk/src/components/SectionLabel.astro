---
interface Props {
  label: string;
  class?: string;
  centered?: boolean;
}

const { label, class: className = '', centered = false } = Astro.props;
---

<div
  class:list={[
    'font-mono text-[0.68rem] font-semibold tracking-[0.2em] uppercase',
    'mb-3 flex items-center gap-3',
    'animate-[neonFlicker_3s_ease-in-out_infinite]',
    centered && 'justify-center',
    className,
  ]}
>
  <span class="text-neon-cyan opacity-60">[</span>
  <span class="w-7 h-px bg-gradient-to-r from-neon-pink to-neon-cyan"></span>
  <span class="text-neon-pink neon-text-pink">{label}</span>
  <span class="w-7 h-px bg-gradient-to-r from-neon-cyan to-neon-pink"></span>
  <span class="text-neon-cyan opacity-60">]</span>
</div>
