---
import SectionLabel from './SectionLabel.astro';

interface SubRole {
  role: string;
  dates: string;
  bullets: string[];
  tech: string[];
}

interface TimelineEntry {
  role: string;
  company: string;
  dates: string;
  location: string;
  bullets: string[];
  tech: string[];
  subRoles?: SubRole[];
}

const timeline: TimelineEntry[] = [
  {
    role: 'Machine Learning Engineer',
    company: 'NeuroTech @ Berkeley',
    dates: 'Jan 2026 — Present',
    location: 'Berkeley, CA',
    bullets: [
      'Achieved 5° RMSE on supervised regression predicting gait angle from 16-channel EEG data for BCI-driven exoskeleton control',
      'Designed a CNN-LSTM architecture — CNN extracts spatial-spectral features, LSTM performs gait angle regression',
      'Preprocessed raw EEG with artifact removal, bandpass filtering, per-channel normalization, and overlapping sliding windows',
    ],
    tech: ['Python', 'PyTorch', 'CNN-LSTM', 'EEG/BCI'],
  },
  {
    role: 'Data Scientist',
    company: 'Synopsys (Contract)',
    dates: 'Aug 2025 — Dec 2025',
    location: 'Berkeley, CA',
    bullets: [
      'Trained and benchmarked regression, random forest, gradient boosting, and GNN models to predict chip power consumption',
      'Built a GNN with PyTorch Geometric and graph attention layers on netlist graphs across ~50–100 designs',
      'Used SHAP analysis to identify dominant features and benchmarked model accuracy and inference speed',
    ],
    tech: ['Python', 'PyTorch', 'TorchGeometric', 'SHAP'],
  },
  {
    role: 'Vice President of Projects',
    company: 'Open Project @ Berkeley',
    dates: 'Jan 2025 — Dec 2025',
    location: 'Berkeley, CA',
    bullets: [
      "Led 15+ developers across 10+ teams in UC Berkeley's largest CS club (150+ members)",
      'Built internal management software and a CAS-authenticated system handling 200+ applications per semester',
      'Designed PostgreSQL schemas with Drizzle ORM and introduced org-wide CI/CD workflows and documentation',
    ],
    tech: ['Next.js', 'PostgreSQL', 'Supabase', 'Drizzle'],
    subRoles: [
      {
        role: 'Lead Developer',
        dates: 'Jan 2025 — May 2025',
        bullets: [
          'Led 2 cross-functional teams of 15+ developers across frontend, backend, and data workstreams',
          'Built an LLM-powered RAG system for chess coaching — improved agent performance by 20%',
          'Cleaned and normalized 500K+ ingredient entries, increasing recognition from <20% to >95%',
        ],
        tech: ['Python', 'React Native', 'Flask', 'SQLite'],
      },
      {
        role: 'Data Engineer',
        dates: 'Aug 2024 — Jan 2025',
        bullets: [
          'Built an async web scraper with 10,000+ automated HTTP requests per run, collecting 100K+ data points',
          'Reduced end-to-end collection time by ~100x and structured 600+ classroom schedules into JSON availability models',
        ],
        tech: ['Python', 'Playwright', 'Pandas'],
      },
    ],
  },
  {
    role: 'Software Engineer',
    company: 'CubeSat',
    dates: 'Aug 2021 — Sep 2024',
    location: 'Irvine, CA',
    bullets: [
      "Engineered the satellite's end-to-end image data stream with error detection and correction",
      'Implemented encoding/decoding pipelines with compression, error correction, and encryption — increasing throughput by ~40%',
      'Integrated low-level USB/UART drivers on Linux using FTD2XX and Xilinx tooling',
    ],
    tech: ['Python', 'C', 'Linux', 'Satellite'],
  },
];
---

<section class="relative z-1 py-32 section-divider" id="experience">
  <div class="max-w-[1200px] mx-auto px-8">
    <SectionLabel label="Experience" class="reveal" />
    <h2 class="reveal reveal-delay-1 font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold tracking-tight leading-[1.15] mb-12 text-text-primary">
      Where I've built things
    </h2>

    <!-- Timeline with neon vertical line -->
    <div class="relative pl-12
                before:content-[''] before:absolute before:left-0 before:top-0 before:bottom-0
                before:w-px before:bg-gradient-to-b before:from-neon-pink before:via-neon-cyan before:to-transparent
                before:shadow-[0_0_8px_rgba(255,45,149,0.3)]">
      {timeline.map((item) => (
        <div class="group relative mb-14 last:mb-0 pl-8 reveal">
          {/* Glowing dot */}
          <div class="absolute -left-[2.9rem] top-2 w-3 h-3 border-2 border-neon-pink rounded-full bg-bg-primary
                      transition-all duration-300
                      group-hover:bg-neon-pink group-hover:shadow-[0_0_12px_rgba(255,45,149,0.6),0_0_24px_rgba(255,45,149,0.3)]" />

          {/* Card with gradient left border */}
          <div class="glass-panel rounded-sm p-6 border-l-2 border-l-transparent
                      bg-gradient-to-r from-bg-card to-transparent
                      hover:border-l-neon-pink transition-all duration-400"
               style="border-image: linear-gradient(to bottom, #ff2d95, #00f0ff) 1; border-image-slice: 0 0 0 1;">
            {/* Header */}
            <div class="flex justify-between items-start flex-wrap gap-2 mb-3">
              <div>
                <div class="font-display text-lg font-bold tracking-tight text-text-primary">
                  {item.role}
                </div>
                <div class="text-sm text-neon-cyan font-medium neon-text-cyan" style="text-shadow: 0 0 5px rgba(0,240,255,0.3);">
                  {item.company}
                </div>
              </div>
            </div>

            {/* Meta */}
            <div class="text-[0.7rem] tracking-[0.08em] uppercase text-text-muted flex gap-5 mb-4 font-mono">
              <span class="text-neon-pink/70">{item.dates}</span>
              <span>{item.location}</span>
            </div>

            {/* Bullets */}
            <ul class="flex flex-col gap-2 list-none">
              {item.bullets.map((bullet) => (
                <li class="text-[0.82rem] text-text-secondary pl-5 relative leading-relaxed
                           before:content-['▹'] before:absolute before:left-0 before:text-neon-pink before:text-[0.7rem]">
                  {bullet}
                </li>
              ))}
            </ul>

            {/* Tech tags */}
            <div class="flex flex-wrap gap-1.5 mt-4">
              {item.tech.map((t) => (
                <span class="text-[0.62rem] font-semibold tracking-[0.08em] uppercase px-3 py-1
                             border border-border rounded-sm text-neon-cyan/70
                             transition-all duration-300
                             group-hover:border-neon-cyan/40 group-hover:text-neon-cyan
                             group-hover:shadow-[0_0_6px_rgba(0,240,255,0.15)]">
                  {t}
                </span>
              ))}
            </div>

            {/* Sub-roles */}
            {item.subRoles?.map((sub) => (
              <div class="mt-8 pt-6 border-t border-border/50">
                <div class="font-display text-base font-bold tracking-tight text-text-primary mb-1">
                  {sub.role}
                </div>
                <div class="text-[0.7rem] tracking-[0.08em] uppercase text-neon-pink/60 mb-4 font-mono">
                  {sub.dates}
                </div>
                <ul class="flex flex-col gap-2 list-none">
                  {sub.bullets.map((bullet) => (
                    <li class="text-[0.82rem] text-text-secondary pl-5 relative leading-relaxed
                               before:content-['▹'] before:absolute before:left-0 before:text-neon-cyan before:text-[0.7rem]">
                      {bullet}
                    </li>
                  ))}
                </ul>
                <div class="flex flex-wrap gap-1.5 mt-4">
                  {sub.tech.map((t) => (
                    <span class="text-[0.62rem] font-semibold tracking-[0.08em] uppercase px-3 py-1
                                 border border-border rounded-sm text-neon-cyan/70
                                 transition-all duration-300
                                 group-hover:border-neon-cyan/40 group-hover:text-neon-cyan">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
