---
import SectionLabel from './SectionLabel.astro';
---

<section
  class="relative z-1 pt-32 pb-16 bg-gradient-to-b from-bg-primary to-bg-secondary section-divider"
  id="contact"
>
  <div class="max-w-[1200px] mx-auto px-8">
    <!-- Content -->
    <div class="text-center max-w-xl mx-auto reveal">
      <SectionLabel label="Contact" centered />

      <!-- HUD-framed heading -->
      <div class="relative inline-block mb-8 hud-frame px-8 py-6">
        <h2 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-tight leading-[1.15] text-text-primary neon-text-multi">
          Initiate<br />Contact<span class="text-neon-cyan">.</span>
        </h2>
      </div>

      <p class="text-sm text-text-secondary mb-10 leading-relaxed font-mono">
        <span class="text-neon-cyan">&gt;</span> I'm always open to interesting conversations about software, AI, data,
        or new opportunities. <span class="text-neon-pink">Drop me a line.</span>
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16">
        <!-- Primary CTA — neon pulse -->
        <a
          href="mailto:devah.schaefers@gmail.com"
          class="inline-flex items-center justify-center gap-2 px-8 py-4
                 text-xs font-bold tracking-[0.1em] uppercase font-mono
                 bg-neon-pink/10 border border-neon-pink rounded-sm text-neon-pink
                 transition-all duration-400 ease-[var(--ease-out-expo)]
                 hover:bg-neon-pink hover:text-bg-primary
                 hover:shadow-[0_0_30px_rgba(255,45,149,0.4),0_0_60px_rgba(255,45,149,0.15)]
                 animate-[neonPulse_3s_ease-in-out_infinite]"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          devah.schaefers@gmail.com
        </a>
        <a
          href="https://www.linkedin.com/in/devahschaefers/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 px-8 py-4
                 text-xs font-bold tracking-[0.1em] uppercase font-mono
                 border border-neon-cyan/40 rounded-sm text-neon-cyan
                 transition-all duration-400 ease-[var(--ease-out-expo)]
                 hover:border-neon-cyan hover:bg-neon-cyan/10
                 hover:shadow-[0_0_30px_rgba(0,240,255,0.3),0_0_60px_rgba(0,240,255,0.1)]"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
            <rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Footer -->
    <footer class="border-t border-border pt-8 flex flex-col sm:flex-row justify-between items-center gap-3">
      <span class="text-[0.65rem] tracking-[0.1em] uppercase text-text-muted font-mono">
        &copy; 2026 Devah Schaefers
      </span>
      <span class="text-[0.65rem] tracking-[0.1em] uppercase text-text-muted font-mono">
        Designed &amp; built with <span class="text-neon-pink neon-text-pink">neon</span> <span class="text-neon-cyan">&amp;</span> <span class="text-neon-cyan neon-text-cyan">precision</span>
      </span>
    </footer>
  </div>
</section>
