---
import SectionLabel from "./SectionLabel.astro";

const skillGroups = [
  {
    category: "Languages",
    items: ["Python", "TypeScript", "Rust", "SQL/PostgreSQL", "C/C++", "Java", "CSS"],
  },
  {
    category: "Frameworks & ML",
    items: ["React/Next.js", "React Native", "Flask", "PyTorch", "TorchGeometric", "scikit-learn", "Pandas/NumPy", "Drizzle ORM"],
  },
  {
    category: "Data & Systems",
    items: ["Data Modeling", "ETL/ELT", "Web Scraping", "Batch Processing", "Async Processing", "Schema Design", "Query Profiling"],
  },
  {
    category: "Tools",
    items: ["Git/GitHub", "GitLab", "Supabase", "PostgreSQL", "SQLite", "CI/CD"],
  },
];
---

<section id="skills" class="py-24 bg-surface">
  <div class="max-w-6xl mx-auto px-6">
    <SectionLabel number="04" label="Skills" />

    <div class="section-grid reveal">
      {skillGroups.map((group) => (
        <div class="col-span-12 md:col-span-3 mb-8 md:mb-0">
          <h3 class="text-xs font-bold tracking-[0.2em] uppercase text-muted mb-4">{group.category}</h3>
          <ul class="space-y-1.5">
            {group.items.map((item) => (
              <li class="text-sm text-fg/80">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
