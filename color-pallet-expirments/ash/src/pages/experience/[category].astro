---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import { categories } from '../../data/experience';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.id },
    props: { cat },
  }));
}

const { cat } = Astro.props;
---

<Layout title={`Devah Schaefers — ${cat.label} Experience`} description={cat.tagline} current="experience">

  <section class="py-10">
    <a
      href="/experience"
      class="text-sm text-text-muted no-underline hover:bg-accent-hover rounded px-1.5 py-0.5 -mx-1.5 inline-block mb-6"
    >
      ← Back to experience
    </a>

    <h2 class="section-heading">{cat.label}</h2>
    <p class="text-text-secondary text-sm mb-8">{cat.tagline}</p>

    <div>
      {cat.experiences.map((exp) => (
        <div class="experience-item">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 mb-0.5">
            <h4 class="font-semibold text-text text-[15px] leading-snug">
              {exp.role}
              <span class="text-text-secondary font-normal"> @ {exp.company}</span>
            </h4>
            <span class="text-sm text-text-muted shrink-0">
              {exp.dates}
            </span>
          </div>

          <ul class="space-y-1 text-sm text-text-secondary list-disc list-outside ml-4 mt-2">
            {exp.bullets.map((bullet) => (
              <li class="leading-relaxed">{bullet}</li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-1.5 mt-3">
            {exp.tech.map((t) => (
              <span class="tech-tag">{t}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    {cat.projects.length > 0 && (
      <div class="mt-12">
        <h3 class="text-xs font-medium text-text-muted tracking-wide uppercase mb-4">Projects</h3>
        <div>
          {cat.projects.map((project) => (
            <div class="experience-item">
              <div class="flex items-start justify-between gap-3 mb-1">
                <h4 class="font-semibold text-text text-[15px] leading-snug">
                  {project.title}
                </h4>
                {project.stat && (
                  <span class="text-xs text-text-muted shrink-0 border border-border rounded-full px-2.5 py-0.5">
                    {project.stat}
                  </span>
                )}
              </div>

              <p class="text-sm text-text-secondary leading-relaxed mb-3">
                {project.description}
              </p>

              <div class="flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <span class="tech-tag">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="mt-8 pt-6 border-t border-border flex flex-wrap gap-3">
      {categories.filter((c) => c.id !== cat.id).map((c) => (
        <a
          href={`/experience/${c.id}`}
          class="bio-link text-sm no-underline hover:bg-accent-hover rounded px-1.5 py-0.5"
        >
          {c.label} →
        </a>
      ))}
    </div>
  </section>

  <Contact />
</Layout>
